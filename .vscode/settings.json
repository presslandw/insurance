{
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.rulers": [120],
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "files.exclude": {
    "**/.git": true,
    "**/.claude": true
  },
  "search.exclude": {
    "**/images/**": true,
    "**/*.pdf": true
  }
}
